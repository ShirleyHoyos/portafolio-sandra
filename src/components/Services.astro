---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-1.04-4.69V10a2.5 2.5 0 0 1 2.5-2.5h1.5"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 1.04-4.69V10a2.5 2.5 0 0 0-2.5-2.5H14.5"/></svg>`,
    title: 'Terapia Individual',
    desc: 'Proceso terapéutico personalizado basado en TCC e intervención interpersonal para el manejo de ansiedad, depresión y otras dificultades emocionales en adultos y adolescentes.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Terapia de Pareja',
    desc: 'Acompañamiento especializado para mejorar la comunicación, resolver conflictos y fortalecer el vínculo afectivo en la relación.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    title: 'Evaluación Psicológica',
    desc: 'Evaluación diagnóstica integral con herramientas estandarizadas para orientar el tratamiento adecuado según cada caso clínico.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Programas de Bienestar',
    desc: 'Diseño e implementación de programas de salud mental para instituciones educativas, empresas y comunidades.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    title: 'Psicología Educativa',
    desc: 'Intervención y acompañamiento psicológico en contextos escolares, con orientación a estudiantes, docentes y familias.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
    title: 'Psicología Organizacional',
    desc: 'Desarrollo de habilidades blandas, gestión del clima organizacional y programas de bienestar del talento humano.',
  },
];
---
<section id="servicios" class="services">
  <div class="container">
    <p class="section-subtitle" data-i18n="services.subtitle">¿En qué puedo ayudarte?</p>
    <h2 class="section-title" data-i18n="services.title">Especialidades</h2>
    <div class="services-grid">
      {services.map((s, i) => (
        <article class="service-card">
          <span class="service-icon" set:html={s.icon} />
          <h3 data-i18n={`services.${i}.title`}>{s.title}</h3>
          <p data-i18n={`services.${i}.desc`}>{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: var(--section-pad-v) 0;
  }

  .services .section-title {
    margin-bottom: var(--space-12);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .service-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    box-shadow: var(--shadow-card);
    transition: var(--transition);
    border-bottom: 3px solid transparent;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-bottom-color: var(--color-primary);
    box-shadow: 0 8px 32px rgba(61, 53, 48, 0.12);
  }

  .service-icon {
    display: block;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .service-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .service-card p {
    font-size: var(--text-sm);
    line-height: 1.7;
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; gap: var(--space-4); }
    .service-card { padding: var(--space-6); }
  }
</style>
